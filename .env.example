# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# Dev: leave as /api/v1 (Vite proxy forwards to backend)
# Production: set to full backend URL e.g. https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=/api/v1

VITE_APP_NAME=بلک منگو
VITE_DELIVERY_FEE=25000


# Dev only — which backend to proxy /api and /uploads to
VITE_API_PROXY_TARGET=http://localhost:3000
